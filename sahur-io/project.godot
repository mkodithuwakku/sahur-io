; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Sahur-io"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"
run/main_scene="res://scenes/main/Main.tscn"

[autoload]

Config="*res://scripts/core/config.gd"
EventBus="*res://scripts/core/event_bus.gd"
AudioManager="*res://scripts/core/audio_manager.gd"
NetworkManager="*res://scripts/network/network_manager.gd"
GameManager="*res://scripts/core/game_manager.gd"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="mobile"
